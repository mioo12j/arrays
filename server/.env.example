# ─── Server ───────────────────────────────────────────────
PORT=4000
NODE_ENV=development
CLIENT_ORIGIN=http://localhost:5173

# ─── Database (PostgreSQL) ────────────────────────────────
# Local: use the PG* vars below.
PGHOST=localhost
PGPORT=5432
PGDATABASE=solar_epc
PGUSER=postgres
PGPASSWORD=postgres
# Cloud (Neon/Supabase/Render): set DATABASE_URL instead (SSL auto-enabled).
# DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# ─── Auth ─────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRES_IN=7d

# ─── Uploads ──────────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_UPLOAD_MB=25
